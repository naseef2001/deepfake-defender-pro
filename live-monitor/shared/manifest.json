{
  "manifest_version": 3,
  "name": "Deepfake Defender",
  "version": "1.0.0",
  "description": "Real-time deepfake detection for Google Meet",
  "permissions": ["storage"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://192.168.152.128:8000/*",
    "wss://192.168.152.128:8001/*"
  ],
  "content_scripts": [{
    "matches": ["https://meet.google.com/*"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
