if PROMETHEUS_AVAILABLE:
    # Clear any existing metrics to avoid duplicates during reload
    collectors = list(REGISTRY._collector_to_names.keys())
    for collector in collectors:
        try:
            REGISTRY.unregister(collector)
        except:
            pass
    
    # Define metrics with unique names
    request_count = Counter(
        'deepfake_api_requests_total',
        'Total API requests', 
        ['method', 'endpoint', 'status']
    )
    detection_count = Counter(
        'deepfake_detections_total',
        'Total detections', 
        ['detector', 'result']
    )
    processing_time = Histogram(
        'deepfake_processing_seconds',
        'Processing time', 
        ['detector']
    )
    active_requests = Gauge(
        'deepfake_active_requests',
        'Active requests'
    )
    detector_health = Gauge(
        'deepfake_detector_health',
        'Detector health status', 
        ['detector']
    )
else:
    # Dummy objects when prometheus not available
    class DummyMetric:
        def inc(self, *args, **kwargs): pass
        def labels(self, *args, **kwargs): return self
        def observe(self, *args, **kwargs): pass
        def set(self, *args, **kwargs): pass
    
    request_count = DummyMetric()
    detection_count = DummyMetric()
    processing_time = DummyMetric()
    active_requests = DummyMetric()
    detector_health = DummyMetric()

class MetricsMiddleware:
    """Middleware for collecting metrics"""
    
    async def __call__(self, request: Request, call_next):
        if PROMETHEUS_AVAILABLE:
            active_requests.inc()
        
        start_time = time.time()
        
        response = await call_next(request)
        
        if PROMETHEUS_AVAILABLE:
            processing_time.labels(detector='api').observe(time.time() - start_time)
            request_count.labels(
                method=request.method,
                endpoint=request.url.path,
                status=response.status_code
            ).inc()
            active_requests.dec()
        
        return response

# =========================================================
# CACHING
# =========================================================

class CacheManager:
    """Cache manager for detection results"""
    
    def __init__(self):
        self.redis = None
        self.in_memory = {}
        
        if settings.REDIS_ENABLED:
            try:
                self.redis = redis.from_url(settings.REDIS_URL)
                logger.info("Redis connected for caching")
            except Exception as e:
                logger.warning(f"Redis connection failed: {e}. Using in-memory cache.")
                self.redis = None
    
    async def get(self, key: str) -> Optional[Dict]:
        """Get cached result"""
        if self.redis:
            data = await self.redis.get(key)
            return json.loads(data) if data else None
        else:
            return self.in_memory.get(key)
    
    async def set(self, key: str, value: Dict, ttl: int = 3600):
        """Cache result"""
        if self.redis:
            await self.redis.setex(key, ttl, json.dumps(value))
        else:
            self.in_memory[key] = value
    
    async def invalidate(self, key: str):
        """Invalidate cache"""
        if self.redis:
            await self.redis.delete(key)
        else:
            self.in_memory.pop(key, None)

cache_manager = CacheManager()

# =========================================================
# BACKGROUND TASKS
# =========================================================

class BackgroundTaskManager:
    """Manager for background tasks"""
    
    def __init__(self):
        self.tasks = {}
        self.results = {}
    
    async def submit(self, task_id: str, coro):
        """Submit background task"""
        self.tasks[task_id] = asyncio.create_task(coro)
        return task_id
    
    async def get_result(self, task_id: str) -> Optional[Any]:
        """Get task result"""
        if task_id in self.results:
            return self.results[task_id]
        
        if task_id in self.tasks:
            if self.tasks[task_id].done():
                try:
                    result = await self.tasks[task_id]
                    self.results[task_id] = result
                    del self.tasks[task_id]
                    return result
                except Exception as e:
                    self.results[task_id] = {'error': str(e)}
                    return self.results[task_id]
        
        return None
    
    def task_exists(self, task_id: str) -> bool:
        """Check if task exists"""
        return task_id in self.tasks or task_id in self.results

task_manager = BackgroundTaskManager()

# =========================================================
# FASTAPI APPLICATION
# =========================================================

@asynccontextmanager
async def lifespan(app: FastAPI):
    """Application lifespan manager"""
    # Startup
    logger.info("=" * 60)
    logger.info(f"Starting {settings.API_TITLE} v{settings.API_VERSION}")
    logger.info("=" * 60)
    
    logger.info(f"Loaded detectors: {detector_manager.get_all_detectors()}")
    logger.info(f"Redis enabled: {settings.REDIS_ENABLED}")
    logger.info(f"Prometheus enabled: {PROMETHEUS_AVAILABLE}")
    logger.info(f"JWT available: {JWT_AVAILABLE}")
    logger.info(f"Web3 available: {WEB3_AVAILABLE}")
    
    yield
    
    # Shutdown
    logger.info("Shutting down...")
    if rate_limiter.redis:
        await rate_limiter.redis.close()
    if cache_manager.redis:
        await cache_manager.redis.close()

app = FastAPI(
    title=settings.API_TITLE,
    version=settings.API_VERSION,
    description=settings.API_DESCRIPTION,
    lifespan=lifespan,
    docs_url=None,  # Disable default docs
    redoc_url=None,
    openapi_url="/api/v1/openapi.json"
)

# Add CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=settings.CORS_ORIGINS,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Add metrics middleware
if PROMETHEUS_AVAILABLE:
    app.middleware("http")(MetricsMiddleware())

