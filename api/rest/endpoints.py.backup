class DetectorManager:
    """Manages all detector instances"""
    
    def __init__(self):
        self.detectors = {}
        self.load_detectors()
    
    def load_detectors(self):
        """Load all enabled detectors"""
        try:
            if settings.ENABLE_MULTI_MODAL and DETECTORS_AVAILABLE:
                self.detectors['multi_modal'] = MultiModalDeepfakeTransformer()
                logger.info("✅ Multi-Modal Transformer loaded")
        except Exception as e:
            logger.error(f"Failed to load Multi-Modal Transformer: {e}")
        
        try:
            if settings.ENABLE_PHYSIOLOGICAL and DETECTORS_AVAILABLE:
                self.detectors['physiological'] = PhysiologicalSignalDetector()
                logger.info("✅ Physiological Detector loaded")
        except Exception as e:
            logger.error(f"Failed to load Physiological Detector: {e}")
        
        try:
            if settings.ENABLE_GAN_FINGERPRINT and DETECTORS_AVAILABLE:
                self.detectors['gan_fingerprint'] = GANFingerprintAnalyzer()
                logger.info("✅ GAN Fingerprint Analyzer loaded")
        except Exception as e:
            logger.error(f"Failed to load GAN Fingerprint Analyzer: {e}")
        
        try:
            if settings.ENABLE_ENF and DETECTORS_AVAILABLE:
                self.detectors['enf'] = ENFAnalyzer()
                logger.info("✅ ENF Analyzer loaded")
        except Exception as e:
            logger.error(f"Failed to load ENF Analyzer: {e}")
        
        try:
            if settings.ENABLE_BLOCKCHAIN and DETECTORS_AVAILABLE:
                self.detectors['blockchain'] = BlockchainVerificationLedger(
                    simulation_mode=settings.BLOCKCHAIN_SIMULATION,
                    provider_url=settings.BLOCKCHAIN_PROVIDER,
                    contract_address=settings.BLOCKCHAIN_CONTRACT
                )
                logger.info("✅ Blockchain Ledger loaded")
        except Exception as e:
            logger.error(f"Failed to load Blockchain Ledger: {e}")
    
    def get_detector(self, name: str):
        """Get detector by name"""
        return self.detectors.get(name)
    
    def get_all_detectors(self):
        """Get all loaded detectors"""
        return list(self.detectors.keys())
    
    def is_loaded(self, name: str) -> bool:
        """Check if detector is loaded"""
        return name in self.detectors

detector_manager = DetectorManager()

# =========================================================
# FILE PROCESSING UTILITIES
# =========================================================

async def validate_file(file: UploadFile) -> str:
    """Validate uploaded file"""
    # Check file size
    file_size = 0
    content = await file.read()
    file_size = len(content)
    await file.seek(0)
    
    if file_size > settings.MAX_FILE_SIZE:
        raise HTTPException(
            status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
            detail=f"File too large. Max size: {settings.MAX_FILE_SIZE / 1024 / 1024}MB"
        )
    
    # Check file extension
    ext = os.path.splitext(file.filename)[1].lower()
    if ext not in settings.ALLOWED_EXTENSIONS:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"File type not allowed. Allowed: {settings.ALLOWED_EXTENSIONS}"
        )
    
    return ext

async def save_upload_file(file: UploadFile) -> Path:
    """Save uploaded file to disk"""
    file_path = settings.UPLOAD_DIR / f"{datetime.now().timestamp()}_{file.filename}"
    
    content = await file.read()
    with open(file_path, "wb") as f:
        f.write(content)
    
    return file_path

def image_to_numpy(image_data: bytes) -> np.ndarray:
    """Convert image bytes to numpy array"""
    nparr = np.frombuffer(image_data, np.uint8)
    img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
    return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

def audio_to_numpy(audio_data: bytes, sample_rate: int = 16000) -> np.ndarray:
    """Convert audio bytes to numpy array"""
    import io
    import wave
    
    with io.BytesIO(audio_data) as audio_io:
        with wave.open(audio_io, 'rb') as wav:
            frames = wav.readframes(wav.getnframes())
            audio = np.frombuffer(frames, dtype=np.int16).astype(np.float32) / 32768.0
    return audio

