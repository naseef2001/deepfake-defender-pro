# =========================================================
# MODELS (Pydantic)
# =========================================================

class Token(BaseModel):
    """JWT Token response"""
    access_token: str
    token_type: str
    expires_in: int

class TokenData(BaseModel):
    """Token payload data"""
    username: Optional[str] = None
    scopes: List[str] = []

class User(BaseModel):
    """User model"""
    username: str
    email: Optional[str] = None
    full_name: Optional[str] = None
    disabled: Optional[bool] = None
    scopes: List[str] = []

class UserInDB(User):
    """User with hashed password"""
    hashed_password: str

class HealthResponse(BaseModel):
    """Health check response"""
    status: str
    version: str
    timestamp: datetime
    detectors: Dict[str, bool]
    services: Dict[str, bool]

class DetectionRequest(BaseModel):
    """Base detection request"""
    model_config = ConfigDict(arbitrary_types_allowed=True)
    
    return_features: bool = False
    priority: str = "normal"  # normal, high, low
    webhook_url: Optional[str] = None
    metadata: Dict[str, Any] = {}

class ImageDetectionRequest(DetectionRequest):
    """Image detection request"""
    url: Optional[str] = None
    base64: Optional[str] = None
    
    @field_validator('url')
    def validate_url(cls, v):
        if v is not None and not v.startswith(('http://', 'https://')):
            raise ValueError('URL must start with http:// or https://')
        return v

class VideoDetectionRequest(DetectionRequest):
    """Video detection request"""
    url: Optional[str] = None
    analyze_frames: int = 30  # Number of frames to analyze
    extract_audio: bool = True

class AudioDetectionRequest(DetectionRequest):
    """Audio detection request"""
    url: Optional[str] = None
    grid_region: Optional[str] = None

class DetectionResponse(BaseModel):
    """Base detection response"""
    request_id: str
    timestamp: datetime
    processing_time: float
    result: Dict[str, Any]
    confidence: float
    is_deepfake: bool
    detectors_used: List[str]

class BatchDetectionRequest(BaseModel):
    """Batch detection request"""
    items: List[Union[ImageDetectionRequest, VideoDetectionRequest, AudioDetectionRequest]]
    parallel: bool = True
    max_concurrency: int = 5

class BatchDetectionResponse(BaseModel):
    """Batch detection response"""
    request_id: str
    timestamp: datetime
    total_time: float
    results: List[DetectionResponse]
    summary: Dict[str, Any]

class ErrorResponse(BaseModel):
    """Error response"""
    error: str
    detail: Optional[str] = None
    status_code: int
    timestamp: datetime

class StatsResponse(BaseModel):
    """Statistics response"""
    total_requests: int
    total_detections: int
    deepfakes_found: int
    average_confidence: float
    average_processing_time: float
    detectors_usage: Dict[str, int]
    uptime: float

