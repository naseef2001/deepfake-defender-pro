security = HTTPBearer(auto_error=False)
oauth2_scheme = OAuth2PasswordBearer(tokenUrl="token", auto_error=False)

def verify_password(plain_password: str, hashed_password: str) -> bool:
    """Verify password (simplified - use proper bcrypt in production)"""
    # In production, use: bcrypt.checkpw(plain_password.encode(), hashed_password.encode())
    return plain_password == "secret"  # Demo only!

def get_user(db, username: str) -> Optional[UserInDB]:
    """Get user from database"""
    if username in db:
        user_dict = db[username]
        return UserInDB(**user_dict)
    return None

def authenticate_user(fake_db, username: str, password: str) -> Optional[UserInDB]:
    """Authenticate user"""
    user = get_user(fake_db, username)
    if not user:
        return None
    if not verify_password(password, user.hashed_password):
        return None
    return user

def create_access_token(data: Dict, expires_delta: Optional[timedelta] = None) -> str:
    """Create JWT access token"""
    to_encode = data.copy()
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(minutes=15)
    
    to_encode.update({"exp": expire})
    
    if JWT_AVAILABLE:
        encoded_jwt = jwt.encode(to_encode, settings.SECRET_KEY, algorithm=settings.ALGORITHM)
    else:
        # Simulated token for development
        encoded_jwt = f"simulated_token_{hashlib.md5(str(to_encode).encode()).hexdigest()}"
    
    return encoded_jwt

async def get_current_user(token: Optional[str] = Depends(oauth2_scheme), 
                          credentials: HTTPAuthorizationCredentials = Depends(security)) -> Optional[User]:
    """Get current user from token"""
    # Extract token from either OAuth2 or Bearer header
    if credentials:
        token = credentials.credentials
    elif not token:
        return None  # No token, return None (not authenticated)
    
    if JWT_AVAILABLE and token and not token.startswith("simulated_token"):
        try:
            payload = jwt.decode(token, settings.SECRET_KEY, algorithms=[settings.ALGORITHM])
            username: str = payload.get("sub")
            if username is None:
                return None
        except jwt.PyJWTError:
            return None
    else:
        # Simulated token - extract username from token
        if token and token.startswith("simulated_token_"):
            # In demo mode, accept any token
            username = "admin"
        else:
            return None
    
    user = get_user(fake_users_db, username)
    if user and not user.disabled:
        return User(**user.model_dump())
    
    return None

async def get_current_active_user(current_user: Optional[User] = Depends(get_current_user)) -> Optional[User]:
    """Get current active user"""
    if current_user and current_user.disabled:
        raise HTTPException(status_code=400, detail="Inactive user")
    return current_user

def check_scopes(required_scopes: List[str]):
    """Check if user has required scopes"""
    async def scope_checker(current_user: Optional[User] = Depends(get_current_active_user)):
        if not current_user:
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="Not authenticated",
                headers={"WWW-Authenticate": "Bearer"},
            )
        
        # Check if user has any of the required scopes
        user_scopes = set(current_user.scopes or [])
        if not any(scope in user_scopes for scope in required_scopes) and "admin:all" not in user_scopes:
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail=f"Not enough permissions. Required scopes: {required_scopes}"
            )
        return current_user
    return scope_checker

# =========================================================
# RATE LIMITING
# =========================================================

class RateLimiter:
    """Rate limiter using Redis or in-memory fallback"""
    
    def __init__(self):
        self.redis = None
        self.in_memory = {}
        
        if settings.REDIS_ENABLED:
            try:
                self.redis = redis.from_url(settings.REDIS_URL)
                logger.info("Redis connected for rate limiting")
            except Exception as e:
                logger.warning(f"Redis connection failed: {e}. Using in-memory rate limiting.")
                self.redis = None
    
    async def is_rate_limited(self, key: str, requests: int = settings.RATE_LIMIT_REQUESTS, 
                              period: int = settings.RATE_LIMIT_PERIOD) -> bool:
        """Check if request is rate limited"""
        if not settings.RATE_LIMIT_ENABLED:
            return False
        
        if self.redis:
            # Redis-based rate limiting
            current = await self.redis.incr(key)
            if current == 1:
                await self.redis.expire(key, period)
            
            return current > requests
        else:
            # In-memory fallback
            now = time.time()
            if key not in self.in_memory:
                self.in_memory[key] = []
            
            # Clean old requests
            self.in_memory[key] = [t for t in self.in_memory[key] if now - t < period]
            
            # Check limit
            if len(self.in_memory[key]) >= requests:
                return True
            
            # Add current request
            self.in_memory[key].append(now)
            return False

rate_limiter = RateLimiter()

async def rate_limit_dependency(request: Request):
    """Rate limiting dependency"""
    # Get client IP
    client_ip = request.client.host if request.client else "unknown"
    
    # Get API key if present
    api_key = request.headers.get(settings.API_KEY_HEADER, "")
    
    # Use combination for rate limiting key
    key = f"rate_limit:{client_ip}:{api_key}"
    
    if await rate_limiter.is_rate_limited(key):
        raise HTTPException(
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail="Rate limit exceeded. Please try again later."
        )

