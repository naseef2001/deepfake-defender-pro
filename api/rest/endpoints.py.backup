@app.post("/detect/image", 
          response_model=DetectionResponse,
          tags=["Detection"],
          dependencies=[Depends(rate_limit_dependency)])
async def detect_image(
    request: Request,
    file: Optional[UploadFile] = File(None),
    url: Optional[str] = Form(None),
    return_features: bool = Form(False),
    current_user: User = Depends(check_scopes(["detect:image", "detect:all"]))
):
    """
    Detect deepfakes in images
    
    Upload an image file or provide a URL to analyze.
    Supports: JPG, PNG, JPEG
    Max file size: 100MB
    """
    request_id = hashlib.md5(f"{time.time()}{os.urandom(8)}".encode()).hexdigest()[:16]
    start_time = time.time()
    
    # Get image data
    image_data = None
    if file:
        ext = await validate_file(file)
        image_data = await file.read()
    elif url:
        # Download from URL
        import aiohttp
        async with aiohttp.ClientSession() as session:
            async with session.get(url) as resp:
                if resp.status != 200:
                    raise HTTPException(status_code=400, detail="Failed to download image")
                image_data = await resp.read()
    else:
        raise HTTPException(status_code=400, detail="Either file or url must be provided")
    
    # Convert to numpy
    try:
        image_np = image_to_numpy(image_data)
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Invalid image: {str(e)}")
    
    # Run detectors
    results = {}
    detectors_used = []
    
    if 'multi_modal' in detector_manager.detectors:
        try:
            multi_result = detector_manager.detectors['multi_modal'].predict(image=image_np)
            if hasattr(multi_result, 'to_dict'):
                results['multi_modal'] = multi_result.to_dict()
            else:
                results['multi_modal'] = {'confidence': 0.5, 'is_deepfake': False}
            detectors_used.append('multi_modal')
        except Exception as e:
            logger.error(f"Multi-modal detection failed: {e}")
    
    if 'gan_fingerprint' in detector_manager.detectors:
        try:
            gan_result = detector_manager.detectors['gan_fingerprint'].analyze_image(image_np)
            if hasattr(gan_result, 'to_dict'):
                results['gan_fingerprint'] = gan_result.to_dict()
            else:
                results['gan_fingerprint'] = {'confidence': 0.5, 'is_deepfake': False}
            detectors_used.append('gan_fingerprint')
        except Exception as e:
            logger.error(f"GAN fingerprint analysis failed: {e}")
    
    # Calculate consensus
    if results:
        confidences = []
        for r in results.values():
            if isinstance(r, dict) and 'confidence' in r:
                confidences.append(r['confidence'])
        avg_confidence = np.mean(confidences) if confidences else 0.5
        is_deepfake = avg_confidence > 0.6
    else:
        avg_confidence = 0.5
        is_deepfake = False
    
    # Cache result
    cache_key = f"image:{request_id}"
    await cache_manager.set(cache_key, {
        'result': results,
        'confidence': avg_confidence,
        'is_deepfake': is_deepfake
    }, ttl=3600)
    
    # Record on blockchain if enabled
    if 'blockchain' in detector_manager.detectors:
        try:
            blockchain_record = detector_manager.detectors['blockchain'].record_detection(
                media_data=image_data,
                detector_id="api_image",
                result="deepfake" if is_deepfake else "real",
                confidence=avg_confidence,
                metadata={'request_id': request_id, 'user': current_user.username if current_user else 'anonymous'}
            )
            if hasattr(blockchain_record, 'to_dict'):
                results['blockchain'] = blockchain_record.to_dict()
        except Exception as e:
            logger.error(f"Blockchain recording failed: {e}")
    
    # Update metrics
    if PROMETHEUS_AVAILABLE:
        detection_count.labels(detector='image_api', result='deepfake' if is_deepfake else 'real').inc()
        processing_time.labels(detector='image_api').observe(time.time() - start_time)
    
    return DetectionResponse(
        request_id=request_id,
        timestamp=datetime.now(),
        processing_time=time.time() - start_time,
        result=results,
        confidence=float(avg_confidence),
        is_deepfake=bool(is_deepfake),
        detectors_used=detectors_used
    )

@app.post("/detect/video", 
          response_model=DetectionResponse,
          tags=["Detection"],
          dependencies=[Depends(rate_limit_dependency)])
async def detect_video(
    request: Request,
    file: UploadFile = File(...),
    analyze_frames: int = Form(30),
    extract_audio: bool = Form(True),
    return_features: bool = Form(False),
    current_user: User = Depends(check_scopes(["detect:video", "detect:all"]))
):
    """
    Detect deepfakes in videos
    
    Upload a video file to analyze.
    Supports: MP4, AVI, MOV
    Max file size: 100MB
    """
    request_id = hashlib.md5(f"{time.time()}{os.urandom(8)}".encode()).hexdigest()[:16]
    start_time = time.time()
    
    # Validate and save file
    ext = await validate_file(file)
    file_path = await save_upload_file(file)
    
    # Process video (simplified - in production use proper video processing)
    results = {}
    detectors_used = []
    
    # Extract frames using OpenCV
    if CV2_AVAILABLE:
        cap = cv2.VideoCapture(str(file_path))
        frames = []
        frame_count = 0
        
        while len(frames) < analyze_frames:
            ret, frame = cap.read()
            if not ret:
                break
            if frame_count % max(1, int(cap.get(cv2.CAP_PROP_FRAME_COUNT) / analyze_frames)) == 0:
                frames.append(frame)
            frame_count += 1
        
        cap.release()
        
        # Analyze frames
        if frames and 'multi_modal' in detector_manager.detectors:
            try:
                # Convert frames to tensor
                frame_tensors = []
                for frame in frames:
                    frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                    frame_tensors.append(frame_rgb)
                
                # Analyze (simplified)
                results['video_analysis'] = {
                    'frames_analyzed': len(frames),
                    'deepfake_probability': 0.5  # Placeholder
                }
                detectors_used.append('video_analysis')
            except Exception as e:
                logger.error(f"Video analysis failed: {e}")
    
    # Cleanup
    file_path.unlink()
    
    return DetectionResponse(
        request_id=request_id,
        timestamp=datetime.now(),
        processing_time=time.time() - start_time,
        result=results,
        confidence=0.5,
        is_deepfake=False,
        detectors_used=detectors_used
    )

@app.post("/detect/audio", 
          response_model=DetectionResponse,
          tags=["Detection"],
          dependencies=[Depends(rate_limit_dependency)])
async def detect_audio(
    request: Request,
    file: UploadFile = File(...),
    grid_region: Optional[str] = Form(None),
    return_features: bool = Form(False),
    current_user: User = Depends(check_scopes(["detect:audio", "detect:all"]))
):
    """
    Detect deepfakes in audio
    
    Upload an audio file to analyze.
    Supports: WAV, MP3, FLAC
    Max file size: 100MB
    """
    request_id = hashlib.md5(f"{time.time()}{os.urandom(8)}".encode()).hexdigest()[:16]
    start_time = time.time()
    
    # Validate and save file
    ext = await validate_file(file)
    file_path = await save_upload_file(file)
    
    results = {}
    detectors_used = []
    
    # Analyze with ENF detector
    if 'enf' in detector_manager.detectors:
        try:
            enf_result = detector_manager.detectors['enf'].analyze_audio(
                audio_path=str(file_path),
                region=grid_region
            )
            if hasattr(enf_result, 'to_dict'):
                results['enf'] = enf_result.to_dict()
            else:
                results['enf'] = {'confidence': 0.5, 'enf_present': False}
            detectors_used.append('enf')
        except Exception as e:
            logger.error(f"ENF analysis failed: {e}")
    
    # Cleanup
    file_path.unlink()
    
    return DetectionResponse(
        request_id=request_id,
        timestamp=datetime.now(),
        processing_time=time.time() - start_time,
        result=results,
        confidence=float(results.get('enf', {}).get('confidence', 0.5)),
        is_deepfake=bool(not results.get('enf', {}).get('enf_present', True)),
        detectors_used=detectors_used
    )

@app.post("/detect/batch", 
          response_model=BatchDetectionResponse,
          tags=["Detection"],
          dependencies=[Depends(rate_limit_dependency)])
async def detect_batch(
    request: BatchDetectionRequest,
    current_user: User = Depends(check_scopes(["detect:batch", "detect:all"]))
):
    """
    Batch detection of multiple files
    
    Process multiple images, videos, or audio files in parallel.
    Max concurrency: 5 parallel tasks
    """
    request_id = hashlib.md5(f"{time.time()}{os.urandom(8)}".encode()).hexdigest()[:16]
    start_time = time.time()
    
    # Process items (simplified - in production use proper batch processing)
    results = []
    
    # Simulate processing
    for item in request.items[:request.max_concurrency]:
        results.append(DetectionResponse(
            request_id=f"{request_id}_{len(results)}",
            timestamp=datetime.now(),
            processing_time=0.1,
            result={"status": "processed"},
            confidence=0.5,
            is_deepfake=False,
            detectors_used=["batch"]
        ))
    
    return BatchDetectionResponse(
        request_id=request_id,
        timestamp=datetime.now(),
        total_time=time.time() - start_time,
        results=results,
        summary={
            "total": len(request.items),
            "processed": len(results),
            "failed": 0
        }
    )

