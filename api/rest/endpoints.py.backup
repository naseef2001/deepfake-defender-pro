@app.get("/blockchain/history/{media_hash}", tags=["Blockchain"])
async def get_blockchain_history(
    media_hash: str,
    current_user: User = Depends(check_scopes(["blockchain:read", "admin:all"]))
):
    """Get blockchain history for a media hash"""
    if 'blockchain' not in detector_manager.detectors:
        raise HTTPException(status_code=503, detail="Blockchain service not available")
    
    history = detector_manager.detectors['blockchain'].get_detection_history(media_hash=media_hash)
    if history and hasattr(history[0], 'to_dict'):
        return {"media_hash": media_hash, "records": [r.to_dict() for r in history]}
    else:
        return {"media_hash": media_hash, "records": history}

@app.get("/blockchain/consensus/{media_hash}", tags=["Blockchain"])
async def get_blockchain_consensus(
    media_hash: str,
    current_user: User = Depends(check_scopes(["blockchain:read", "admin:all"]))
):
    """Get consensus from blockchain records"""
    if 'blockchain' not in detector_manager.detectors:
        raise HTTPException(status_code=503, detail="Blockchain service not available")
    
    consensus = detector_manager.detectors['blockchain'].verify_detection_consensus(media_hash=media_hash)
    if hasattr(consensus, 'to_dict'):
        return consensus.to_dict()
    else:
        return consensus

# =========================================================
# ASYNC/TASK ENDPOINTS
# =========================================================

@app.post("/tasks/submit", tags=["Tasks"])
async def submit_task(
    task_type: str = Form(...),
    file: UploadFile = File(...),
    current_user: User = Depends(check_scopes(["tasks:submit", "admin:all"]))
):
    """Submit a task for async processing"""
    task_id = hashlib.md5(f"{time.time()}{os.urandom(8)}".encode()).hexdigest()
    
    # Save file
    file_path = await save_upload_file(file)
    
    # Submit task based on type
    if task_type == "image":
        # Create a mock coroutine for now
        async def mock_task():
            return {"status": "completed", "type": "image", "task_id": task_id}
        coro = mock_task()
    elif task_type == "video":
        async def mock_task():
            return {"status": "completed", "type": "video", "task_id": task_id}
        coro = mock_task()
    elif task_type == "audio":
        async def mock_task():
            return {"status": "completed", "type": "audio", "task_id": task_id}
        coro = mock_task()
    else:
        raise HTTPException(status_code=400, detail="Invalid task type")
    
    await task_manager.submit(task_id, coro)
    
    return {
        "task_id": task_id,
        "status": "submitted",
        "check_url": f"/tasks/status/{task_id}"
    }

@app.get("/tasks/status/{task_id}", tags=["Tasks"])
async def get_task_status(task_id: str):
    """Get task status and result"""
    if not task_manager.task_exists(task_id):
        raise HTTPException(status_code=404, detail="Task not found")
    
    result = await task_manager.get_result(task_id)
    
    if result:
        return {"task_id": task_id, "status": "completed", "result": result}
    else:
        return {"task_id": task_id, "status": "processing"}

# =========================================================
# WEBSOCKET FOR REAL-TIME DETECTION
# =========================================================

@app.websocket("/ws/detect")
async def websocket_detect(websocket: WebSocket):
    """WebSocket endpoint for real-time detection"""
    await websocket.accept()
    
    try:
        while True:
            # Receive message
            data = await websocket.receive_json()
            
            if data['type'] == 'frame':
                # Process frame (simplified)
                result = {
                    'type': 'detection',
                    'timestamp': time.time(),
                    'deepfake_probability': 0.3,
                    'is_deepfake': False
                }
                await websocket.send_json(result)
            
            elif data['type'] == 'ping':
                await websocket.send_json({'type': 'pong'})
            
            elif data['type'] == 'audio':
                # Process audio chunk (simplified)
                result = {
                    'type': 'detection',
                    'timestamp': time.time(),
                    'deepfake_probability': 0.2,
                    'is_deepfake': False
                }
                await websocket.send_json(result)
    
    except WebSocketDisconnect:
        logger.info("WebSocket client disconnected")
    except Exception as e:
        logger.error(f"WebSocket error: {e}")

